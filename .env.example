# Copy to .env for local runs. Do not commit real tokens.

# Streamlit/demo app
APP_ENV=development
STREAMLIT_SERVER_PORT=8501

# OpenAI-compatible Gemma endpoint.
# If you run the compose service from this repo, use:
#   GEMMA_BASE_URL=http://localhost:18081/v1
# If the app runs inside compose, compose overrides this to:
#   http://local-llm-gemma4e4b:8080/v1
GEMMA_BASE_URL=http://localhost:18081/v1
GEMMA_API_KEY=local-llm
GEMMA_MODEL=ggml-org/gemma-4-E4B-it-GGUF
GEMMA_REQUEST_TIMEOUT_SECONDS=120
GEMMA_REWRITE_TIMEOUT_SECONDS=4
GEMMA_ENABLE_PLANNER=true
GEMMA_ENABLE_FAST_ROUTER=true
GEMMA_ENABLE_COMPOSER=true
GEMMA_ENABLE_STRUCTURED_COMPOSER=true
GEMMA_ENABLE_VISION=true

# Hugging Face token may be required to download gated model weights.
HF_TOKEN=

# llama.cpp local model service defaults
LOCAL_LLM_GEMMA4E4B_HF_REPO=ggml-org/gemma-4-E4B-it-GGUF
LOCAL_LLM_GEMMA4E4B_HF_FILE=gemma-4-E4B-it-Q4_K_M.gguf
LOCAL_LLM_GEMMA4E4B_MODEL_PATH=
LOCAL_LLM_GEMMA4E4B_PORT=18081
LOCAL_LLM_GEMMA4E4B_CTX_SIZE=8192
LOCAL_LLM_GEMMA4E4B_THREADS=8
LOCAL_LLM_GEMMA4E4B_PARALLEL=1
LOCAL_LLM_GEMMA4E4B_GPU_LAYERS=999
LOCAL_LLM_GEMMA4E4B_CUDA_ARCH=89-real
LOCAL_LLM_API_KEY=local-llm
